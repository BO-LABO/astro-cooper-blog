---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import ScrollProgress from '~/components/layout/ScrollProgress.astro';
import { client } from '~/library/microcms';
import { isRtl, useTranslations } from '~/i18n/utils';
import { languages } from '~/i18n/ui';
import translate from 'translate';

// デフォルトでGoogle翻訳エンジンを使用するように設定
translate.engine = 'google';

export async function getStaticPaths() {
  const response = await client.get({ endpoint: 'blogs' });
  const posts = response.contents;

  return posts.flatMap((post: any) =>
    Object.keys(languages).map((lang) => ({
      params: { lang, id: post.id },
      props: { post },
    }))
  );
}

const { post } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

// HTMLタグを壊さずに安全にGoogle翻訳する関数
async function translateHtml(htmlText: string, targetLang: string) {
  if (!htmlText) return '';
  try {
    // 1. HTMLタグを退避するプレースホルダーの配列を作成
    const placeholders: string[] = [];
    let placeholderIndex = 0;
    
    // <...> で囲まれたHTMLタグを検出し、一時的に [[数字]] に置き換える
    const maskedHtml = htmlText.replace(/<[^>]+>/g, (match) => {
      placeholders.push(match);
      return ` [[${placeholderIndex++}]] `;
    });
    
    // 2. テキストだけになったデータをGoogle翻訳に送る
    const translatedMasked = await translate(maskedHtml, { from: 'ja', to: targetLang });
    
    // 3. [[数字]] のプレースホルダーを、退避させておいた元のHTMLタグに戻す
    const finalHtml = translatedMasked.replace(/\[\[(\d+)\]\]/g, (match, indexStr) => {
      const index = parseInt(indexStr, 10);
      return placeholders[index] || match;
    });
    
    return finalHtml;
  } catch (error) {
    console.error('Google translation failed:', error);
    return htmlText; // 失敗時は元の日本語をそのまま表示して壊れるのを防ぐ
  }
}

let displayTitle = post.title;
let displayContent = post.content;

// 英語モード(en)の場合のみ、ビルド時に自動でGoogle翻訳を実行する
if (lang === 'en') {
  try {
    displayTitle = await translate(post.title, { from: 'ja', to: 'en' });
    displayContent = await translateHtml(post.content, 'en');
  } catch (e) {
    console.error("Translation run error:", e);
  }
}
---

<Layout title={displayTitle} description={displayTitle} image={post.eyecatch?.url} imageAlt={displayTitle} article={true}>
  <ScrollProgress />
  <article class="max-w-4xl mx-auto px-6 pt-40 pb-20">
    <div class="mb-8">
      <a href={`/${lang}/blog/microcms`} class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`w-4 h-4 ${isRtl(lang) ? 'rotate-180' : ''}`}><path d="m15 18-6-6 6-6"/></svg>
        {t['blog.back']}
      </a>
    </div>

    <div class="mb-12 text-center">
      {post.eyecatch && (
        <div class="rounded-2xl overflow-hidden mb-8 border border-black/10 dark:border-white/10 shadow-2xl">
          <img src={post.eyecatch.url} alt={displayTitle} loading="eager" class="w-full object-cover aspect-video" />
        </div>
      )}

      <h1 class="text-3xl md:text-6xl font-display font-bold mb-6 break-words bg-linear-to-br from-zinc-900 via-zinc-900 to-zinc-600 dark:from-white dark:via-white dark:to-white bg-clip-text text-transparent">
        {displayTitle}
      </h1>

      <hr class="border-black/10 dark:border-white/10" />
    </div>

    <div class="prose prose-lg mx-auto prose-img:rounded-xl prose-headings:font-display prose-headings:font-bold prose-a:text-primary hover:prose-a:text-primary/80 dark:prose-invert" set:html={displayContent} />
  </article>
</Layout>
