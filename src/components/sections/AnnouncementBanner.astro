---
interface Props {
  id: string;
  message: string;
  link?: string;
  linkText?: string;
}
const { message, link, linkText } = Astro.props;
---
<div 
  id="announcement-banner" 
  class="bg-primary text-white relative overflow-hidden"
  role="alert"
>
  <div class="flex items-center justify-between px-4 py-2 gap-3">
    <div class="flex-1 overflow-hidden">
      <div class="marquee-track whitespace-nowrap text-sm font-medium">
        <span class="marquee-content">{message}&nbsp;&nbsp;&nbsp;{message}&nbsp;&nbsp;&nbsp;</span>
      </div>
    </div>
    {link && (
      <a 
        href={link} 
        class="shrink-0 text-xs font-bold bg-white text-primary px-3 py-1 rounded-full hover:bg-white/90 transition-all whitespace-nowrap"
      >
        {linkText}
      </a>
    )}
  </div>
</div>

<style>
  .marquee-track {
    display: inline-block;
    animation: marquee 18s linear infinite;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>
