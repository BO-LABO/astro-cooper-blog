---
interface Props {
  id: string;
  message: string;
  link?: string;
  linkText?: string;
}
const { message, link, linkText } = Astro.props;
---
<div 
  id="announcement-banner" 
  class="bg-primary text-white relative overflow-hidden"
  role="alert"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-center py-2 text-sm font-medium gap-2">
      <span>{message}</span>
      {link && (
        <a 
          href={link} 
          class="underline decoration-white/50 hover:decoration-white transition-all underline-offset-4"
        >
          {linkText}
        </a>
      )}
    </div>
  </div>
</div>
